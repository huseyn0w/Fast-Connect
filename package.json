{
  "name": "fast-connect",
  "version": "2.0.0",
  "private": true,
  "description": "Standalone WebRTC video conferencing — Vite/React client + Socket.IO/PeerJS server",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:client": "npm run dev --workspace @fast-connect/client",
    "dev:server": "npm run dev --workspace @fast-connect/server",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace @fast-connect/server",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspace @fast-connect/client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huseyn0w/fast-connect.git"
  },
  "keywords": ["react", "vite", "typescript", "express", "webrtc", "peerjs", "socket.io"],
  "author": "Elman Hüseynov",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/huseyn0w/fast-connect/issues"
  },
  "homepage": "https://github.com/huseyn0w/fast-connect#readme",
  "engines": {
    "node": ">=20"
  }
}
